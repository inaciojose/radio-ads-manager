# =============================================================
# Configuração de PRODUÇÃO — Docker Compose
# Copie este arquivo para .env.prod e ajuste os valores.
# NUNCA commite .env.prod no repositório.
# =============================================================

# -------------------------------------------------------------
# Banco de dados (variáveis usadas pelo serviço postgres: e pela API)
# -------------------------------------------------------------
POSTGRES_USER=radio_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=radio_ads

# Aponta para o serviço "postgres" do docker-compose (não localhost)
DATABASE_URL=postgresql+psycopg2://radio_user:TROQUE_POR_SENHA_FORTE@postgres:5432/radio_ads

# -------------------------------------------------------------
# Segurança / Autenticação
# -------------------------------------------------------------
AUTH_TOKEN_SECRET=TROQUE_POR_CHAVE_ALEATORIA_COM_32_OU_MAIS_CARACTERES
AUTH_TOKEN_EXPIRE_HOURS=8

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
INITIAL_ADMIN_NOME=Administrador

# -------------------------------------------------------------
# Ambiente da aplicação
# -------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_RELOAD=false
API_DOCS_ENABLED=false
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=2

# -------------------------------------------------------------
# CORS — lista de origens permitidas (separadas por vírgula)
# Em produção use o domínio/IP real do servidor.
# Se o frontend está no mesmo nginx (porta 80) do mesmo host,
# o proxy /api/ faz tudo passar pela mesma origem — basta colocar
# a URL pública do servidor.
# -------------------------------------------------------------
CORS_ALLOW_ORIGINS=http://SEU-IP-OU-DOMINIO

# -------------------------------------------------------------
# Frontend (porta exposta pelo nginx no host)
# -------------------------------------------------------------
FRONTEND_PORT=80

# -------------------------------------------------------------
# Logs do Zara Studio — caminhos NO HOST (Windows)
#
# Estes diretórios serão montados dentro do container como:
#   /mnt/logs/fm      (LOG_DIR_FM)
#   /mnt/logs/104_7   (LOG_DIR_104)
#
# No Windows com Docker Desktop, use barras normais:
#   LOG_DIR_FM=C:/ZaraStudio/Registro FM
# No Linux, use a UNC ou caminho local onde os logs ficam acessíveis.
# -------------------------------------------------------------
LOG_DIR_FM=C:/ZaraStudio/Registro FM
LOG_DIR_104=C:/ZaraStudio/Registro 104_7

# -------------------------------------------------------------
# Monitor de logs — configuração interna (caminhos dentro do container)
#
# LOG_SOURCES: frequencia=caminho_dentro_do_container; ...
# Use os pontos de montagem /mnt/logs/fm e /mnt/logs/104_7.
# -------------------------------------------------------------
LOG_SOURCES=102.7=/mnt/logs/fm;104.7=/mnt/logs/104_7

# Prefixo dos arquivos de chamada (propaganda).
# Para UNC do Zara Studio, coloque o caminho como aparece nos logs.
# Exemplo Windows local:   J:\AZARASTUDIO\CHAMADAS
# Exemplo UNC:             \\servidor\compartilhamento\AZARASTUDIO\CHAMADAS
CHAMADAS_BASE_PATH=\\SERVIDOR\COMPARTILHAMENTO\AZARASTUDIO\CHAMADAS

# Fuso horário dos timestamps nos arquivos de log
LOG_TIMEZONE=America/Fortaleza

# -------------------------------------------------------------
# Monitor — performance (valores padrão geralmente adequados)
# -------------------------------------------------------------
REQUEST_TIMEOUT=8
REQUEST_RETRIES=3
INGEST_BATCH_SIZE=100
WATCH_DEBOUNCE_SECONDS=1.5
MONITOR_API_KEY=TROQUE_POR_API_KEY_DE_SERVICO

# -------------------------------------------------------------
# Backup automático
# Caminho NO HOST onde os dumps serão salvos.
# O container monta este diretório em /app/backups.
# -------------------------------------------------------------
BACKUP_DIR=./backups

# -------------------------------------------------------------
# Janelas sem auditoria automática (opcional)
# Formato: frequencia|dias_iso(1-7)|HH:MM-HH:MM|motivo; ...
# Exemplo: bloqueia seg-sex 11h-14h na 102.7 (entrada ao vivo/OBS)
# -------------------------------------------------------------
# AUTO_AUDIT_BLOCK_WINDOWS=102.7|1-5|11:00-14:00|obs_video
